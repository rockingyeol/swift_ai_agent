# =============================================================================
# .dockerignore — SWIFT AI Agent Python 이미지 빌드 제외 목록
#
# 목적:
#   1. 불필요한 파일을 빌드 컨텍스트에서 제외 → docker build 전송 크기 감소
#   2. 민감 정보(.env, 키 파일)가 이미지에 포함되지 않도록 차단
#   3. 대용량 데이터·모델 파일이 실수로 포함되는 것 방지
# =============================================================================

# ── Git ───────────────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── 시크릿 · 환경변수 (이미지에 절대 포함 금지) ───────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/

# ── Python 캐시 · 가상환경 ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
env/
.Python
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── 테스트 · CI ───────────────────────────────────────────────────────────────
tests/
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/
.tox/

# ── 개발 도구 ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── 문서 ─────────────────────────────────────────────────────────────────────
docs/
*.md
!README.md
plan.md

# ── 대용량 데이터 (볼륨으로 마운트) ──────────────────────────────────────────
data/
*.pdf
*.csv
audit.jsonl
audit_*.jsonl
*.db
*.sqlite

# ── HuggingFace / 모델 캐시 (볼륨으로 마운트) ────────────────────────────────
.hf_cache/
*.bin
*.safetensors
*.ot
*.onnx

# ── Java 하위 프로젝트 (별도 Dockerfile 사용) ────────────────────────────────
prowide-svc/

# ── Docker 설정 파일 자체 ──────────────────────────────────────────────────────
Dockerfile*
docker-compose*.yml
.dockerignore

# ── 기타 ─────────────────────────────────────────────────────────────────────
*.log
logs/
tmp/
.tmp/
