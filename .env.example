# vLLM (Llama 3.1 70B) - 온프레미스
VLLM_BASE_URL=http://llm-svc.internal:8000/v1
VLLM_API_KEY=dummy
VLLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                          # Qdrant Cloud 사용 시 API Key 설정
QDRANT_COLLECTION=swift_guidebook

# MT 가이드북 PDF 경로 (setup_qdrant.py --ingest 시 사용)
GUIDEBOOK_PDF=./data/SR_2025_MT101.pdf

# Prowide REST 마이크로서비스
PROWIDE_URL=http://prowide-svc.internal:8080

# BGE-m3 / Reranker (로컬 경로 또는 HuggingFace 캐시)
EMBED_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# PII Vault (운영환경에서는 HashiCorp Vault 등으로 교체)
PII_VAULT_BACKEND=memory

# Audit log
AUDIT_LOG_PATH=./audit.jsonl

# HITL
HITL_ENABLED=true
HITL_RISK_THRESHOLD=high
