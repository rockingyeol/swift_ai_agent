# =============================================================================
# .env.example — SWIFT AI Agent 환경변수 템플릿
#
# 사용법:
#   cp .env.example .env
#   # .env 에서 실제 값으로 수정 후 docker compose up
#
# 보안 정책:
#   - .env 는 절대 git commit 하지 마세요 (.gitignore 에 등록 필수)
#   - API 키 등 시크릿은 운영환경에서 HashiCorp Vault / AWS Secrets Manager 로 교체
#   - docker-compose.yml 의 environment[] 섹션이 .env 값을 override 함
#     (PROWIDE_URL, QDRANT_URL 은 컨테이너 DNS 로 자동 설정됨)
# =============================================================================

# ── vLLM / LLM 서비스 ────────────────────────────────────────────────────────
# 온프레미스 vLLM 서버 또는 OpenAI 호환 엔드포인트
VLLM_BASE_URL=http://llm-svc.internal:8000/v1
VLLM_API_KEY=your-vllm-api-key-here
VLLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# ── Qdrant Vector DB ─────────────────────────────────────────────────────────
# docker-compose 환경: compose environment[] 에서 http://qdrant:6333 으로 override 됨
# 로컬 직접 실행 환경에서만 아래 값을 사용
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# Qdrant Cloud 사용 시만 위 값에 API Key 설정
QDRANT_COLLECTION=swift_guidebook

# ── Prowide REST 마이크로서비스 ───────────────────────────────────────────────
# docker-compose 환경: compose environment[] 에서 http://prowide-svc:8080 으로 override 됨
PROWIDE_URL=http://localhost:8080
# Prowide HTTP 요청 타임아웃 (초). 고지연 네트워크 환경에서 늘려서 사용
PROWIDE_TIMEOUT=10.0
# 그래프 전체 실행 타임아웃 (초). 초과 시 408 반환
GRAPH_TIMEOUT=300

# ── BGE-M3 임베딩 / Reranker ─────────────────────────────────────────────────
# 최초 실행 시 HuggingFace Hub 에서 자동 다운로드 (hf_cache 볼륨에 캐싱)
EMBED_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── 가이드북 PDF / 디렉토리 경로 (qdrant 인덱싱 시 사용) ─────────────────────
# docker-compose: ./data 는 /app/data:ro 로 마운트됨

# 단건 인제스트 (setup_qdrant.py --ingest)
GUIDEBOOK_PDF=./data/MT/Category1/SR_2025_MT101.pdf

# 일괄 인제스트 (ingest_mt_all.py) — 하위 카테고리 폴더 전체 자동 탐색
MT_DIR=./data/MT

# MX 단건 인제스트 (setup_qdrant.py --ingest-mx)
MX_GUIDEBOOK_PDF=./data/MX/pacs/MX_pacs_008_001_14.pdf

# MX 일괄 인제스트 (ingest_mx_all.py) — 하위 카테고리 폴더 전체 자동 탐색
MX_DIR=./data/MX

# ── PII Vault 백엔드 ──────────────────────────────────────────────────────────
# 운영환경: vault (HashiCorp) | aws_secrets | gcp_secrets
# 개발·테스트: memory (프로세스 메모리, 재시작 시 초기화)
PII_VAULT_BACKEND=memory

# ── 감사 로그 ────────────────────────────────────────────────────────────────
# docker-compose: audit_data 볼륨의 /app/logs/audit.jsonl 로 override 됨
AUDIT_LOG_PATH=./audit.jsonl

# ── HITL 설정 ─────────────────────────────────────────────────────────────────
HITL_ENABLED=true
HITL_RISK_THRESHOLD=high

# ── Docker Compose 포트 설정 (호스트 바인딩 포트 변경 시 사용) ────────────────
SWIFT_AGENT_HOST_PORT=8000
PROWIDE_HOST_PORT=8080
QDRANT_HOST_PORT=6333
QDRANT_GRPC_PORT=6334

# ── 로그 레벨 ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Java 힙 설정 (prowide-svc) ────────────────────────────────────────────────
PROWIDE_JAVA_OPTS=-Xmx512m
